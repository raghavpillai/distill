{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "export"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "pipeline": {
      "cache": false,
      "outputs": ["data/**"]
    },
    "export": {
      "dependsOn": ["pipeline"],
      "outputs": ["data/web.json"],
      "inputs": ["data/messages.parquet", "data/clustered.parquet", "data/clusters.parquet"]
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    }
  }
}
