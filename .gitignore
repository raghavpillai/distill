# Stray local test scripts (snap.py, click_audit.py, etc) accumulate at root
# from manual UI debugging. Keep them out of the repo.
/*.py
!scripts/*.py

# All pipeline outputs are derived from the user's local
# ~/.claude/projects/*.jsonl + LLM calls. They contain the developer's
# personal conversation history — regenerable, sensitive, and large.
# Run `bun run pipeline` to regenerate.
packages/pipeline/data/*.json
packages/pipeline/data/sessions/
packages/pipeline/data/*.parquet
packages/pipeline/data/*.npy
apps/web/dist/
